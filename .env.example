# === GCP Configuration ===
# Path to your Service Account JSON file (Requires BigQuery and Compute roles)
# Example: GOOGLE_APPLICATION_CREDENTIALS="/Users/username/keys/gcp-finops-sa.json"
GOOGLE_APPLICATION_CREDENTIALS=""

# Your specific Google Cloud Project ID where the BigQuery Billing Export resides.
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"

# === AWS Configuration ===
# The standard AWS authentication keys. If running locally, you can use AWS_PROFILE instead
# and leave the keys empty.
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# Fallback default region for AWS resource querying when determining location.
AWS_REGION="us-east-1"

# Automatically map to your ~/.aws/credentials profile. 
# AWS_PROFILE="default"

# === Azure Configuration ===
# The underlying Directory (Tenant) ID for your Azure active directory.
AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"

# Equivalent to the App ID of your Azure Service Principal assigned the Cost Management Reader role.
AZURE_CLIENT_ID="11111111-1111-1111-1111-111111111111"

# The literal secret password generated for the Azure Service Principal.
AZURE_CLIENT_SECRET="your-azure-client-secret"

# The specific subscription UUID you want OpsYield to scan costs from.
AZURE_SUBSCRIPTION_ID="22222222-2222-2222-2222-222222222222"

# === Kubernetes Cost Configuration ===
# Points the internal Kubernetes collector to the localized OpenCost installation REST API.
# Should include the protocol and port (default is 9003 for OpenCost deployments).
OPENCOST_URL=http://localhost:9003

# === Application Settings ===
# Central application log verbosity configuration parameter.
LOG_LEVEL="INFO" # Options: DEBUG, INFO, WARNING, ERROR

# Specifies the context interface standard. Must be "stdio" for normal command line MCPs.
MCP_TRANSPORT="stdio" # Options: stdio, sse
